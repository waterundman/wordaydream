{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    /* v1.5.3 fix V2-P1-002: 分阶段启用 strict 模式.
       第一阶段: strictNullChecks + noImplicitAny.
       后续版本 (v1.6.0) 再启用 strictFunctionTypes / strictBindCallApply /
       strictPropertyInitialization / alwaysStrict 等完整 strict 选项. */
    "strictNullChecks": true,
    "noImplicitAny": true
  },
  "include": ["src", "netlify/edge-functions"]
}
