# ============================================
# Wordaydream LLM Provider API Keys (TEMPLATE)
# ============================================
# 复制本文件为 .env, 填入你的 API key 后, 在浏览器设置面板选择对应 provider 即可
# 留空 = 使用 mock 模式 (内置示例数据)
# API key 优先从此文件读, 如果环境变量未设置, 则回退到浏览器 localStorage (SettingsPanel 中填入)

# v1.5.2 fix M15: 仅列出代码实际支持的 3 个 provider (openai/anthropic/deepseek).
# 旧的 kimi/qwen/minimax 在 v1.4.0 Stage 1/2 已删除函数式实现, 残留 env 是死代码.

# 海外 LLM
VITE_OPENAI_API_KEY=your-openai-api-key-here
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here

# 国内 LLM (OpenAI 兼容协议)
VITE_DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ============================================
# 自定义 Base URL (可选, 留空使用默认)
# ============================================
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_ANTHROPIC_BASE_URL=https://api.anthropic.com
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ============================================
# 自定义模型 (可选, 留空使用默认)
# ============================================
VITE_OPENAI_MODEL=gpt-4o-mini
VITE_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
VITE_DEEPSEEK_MODEL=deepseek-chat

# ============================================
# v1.3.0+ Edge Function 代理 (服务端 LLM 代理, 隐藏 API key)
# ============================================
# 默认 provider: openai | anthropic | deepseek (v1.4.0 Stage 1/2 仅支持这 3 个)
VITE_LLM_PROVIDER=openai

# Edge Function 路径 (本地 netlify dev = http://localhost:8888, 部署后 = 站点 URL)
VITE_LLM_PROXY_URL=http://localhost:8888/.netlify/edge-functions/llm-proxy

# LLM 生成参数 (前端 fallback 默认值)
VITE_LLM_MAX_TOKENS=2048
VITE_LLM_TEMPERATURE=0.7
VITE_LLM_RETRY_ATTEMPTS=3
VITE_LLM_TIMEOUT_MS=30000

# ============================================
# v1.5.0 Stage 4 P2_1 灰度发布 (R-11)
# ============================================
# 灰度比例 0-100: 仅当 VITE_LLM_PROVIDER=openai 时生效.
# 100 = 100% 走 openai (默认, 与 v1.4.1 行为一致).
# 10  = 10% 走 openai, 90% 走 anthropic 灰度分流.
# 注: deepseek 不参与灰度, 仅显式 VITE_LLM_PROVIDER=deepseek 时启用.
VITE_LLM_GRAYSCALE=100

# ============================================
# v1.4.1 Stage 2 离线模式 / PWA
# ============================================
# 离线时是否自动 fallback 到 mock provider (默认 true).
VITE_OFFLINE_FALLBACK=true

# 应用版本号 (与 package.json version 同步, 用于 SW 缓存失效).
VITE_APP_VERSION=1.5.2
